{
	"name": "@ruan-cat-10wms/root",
	"private": true,
	"version": "0.0.0",
	"author": "ruan-cat",
	"license": "ISC",
	"description": "阮喵喵10wms项目的monorepo根目录。用来实现一个后台项目的升级改造。",
	"main": "index.js",
	"type": "module",
	"packageManager": "pnpm@10.14.0",
	"engines": {
		"node": ">=22.14.0"
	},
	"scripts": {
		"build": "turbo build",
		"up-taze": "pnpm -w up @ruan-cat/taze-config -L && npx taze -r",
		"deploy-vercel": "turbo do-deploy-vercel",
		"test": "vitest --ui --watch --api.port=4000",
		"format": "pnpm -r format",
		"changeset:add": "changeset add",
		"changeset:version": "changeset version && changeset tag",
		"git:push": "git push --follow-tags",
		"build:docs": "turbo build:docs",
		"create-code-workspace": "tsx ./scripts/generate.code-workspace.ts --name=10wms-项目改造工作区",
		"preinstall": "npx only-allow pnpm && npm run corepack:pnpm",
		"corepack:pnpm": "corepack enable && corepack install",
		"git:fetch": "git fetch -p",
		"clear": "pnpm run clear:deps && pnpm run clear:cache",
		"clear:deps": "rimraf -g '**/{node_modules,package-lock.json,pnpm-lock.yaml}'",
		"clear:cache": "rimraf -g '**/{dist,.turbo,.vercel,.cache,.temp}'",
		"changeset:init": "changeset init",
		"changeset:publish": "changeset publish",
		"turbo:publish": "turbo do-publish",
		"up-ruan-cat": "pnpm -w up '@ruan-cat/*@latest' && pnpm -r up '@ruan-cat/*@latest'",
		"format:*": "prettier --experimental-cli --write . --ignore-path ./.config/.prettierignore --ignore-path .gitignore",
		"do-deploy-vercel": "tsx ./scripts/vercel-deploy-tool.ts"
	},
	"devDependencies": {
		"@antfu/eslint-config": "^4.19.0",
		"@changesets/cli": "^2.29.6",
		"@prettier/plugin-oxc": "^0.0.4",
		"@ruan-cat/commitlint-config": "^1.4.0",
		"@ruan-cat/domains": "^0.9.0",
		"@ruan-cat/generate-code-workspace": "^0.4.13",
		"@ruan-cat/taze-config": "^0.2.0",
		"@ruan-cat/utils": "^4.10.0",
		"@ruan-cat/vercel-deploy-tool": "^0.11.0",
		"@ruan-cat/vitepress-preset-config": "^1.1.0",
		"@svitejs/changesets-changelog-github-compact": "^1.2.0",
		"@types/eslint-config-prettier": "^6.11.3",
		"@types/js-yaml": "^4.0.9",
		"@types/lodash-es": "^4.17.12",
		"@types/node": "^22.17.2",
		"@vitest/ui": "^3.2.4",
		"@vuepress/bundler-vite": "2.0.0-rc.20",
		"@vuepress/plugin-slimsearch": "2.0.0-rc.80",
		"commander": "^13.1.0",
		"commitizen": "^4.3.1",
		"consola": "^3.4.2",
		"cross-env": "^7.0.3",
		"cz-git": "^1.12.0",
		"eslint": "^9.33.0",
		"eslint-config-prettier": "^10.1.8",
		"eslint-config-turbo": "^2.5.6",
		"eslint-plugin-prettier": "^5.5.4",
		"js-yaml": "^4.1.0",
		"lodash-es": "^4.17.21",
		"only-allow": "^1.2.1",
		"pkg-types": "^2.2.0",
		"prettier": "^3.6.2",
		"prettier-plugin-lint-md": "^1.0.1",
		"rimraf": "^6.0.1",
		"taze": "^19.1.0",
		"tsx": "^4.20.4",
		"turbo": "^2.5.6",
		"type-fest": "^4.41.0",
		"type-plus": "^7.6.2",
		"typescript": "^5.9.2",
		"typescript-lodash": "^0.2.2",
		"vercel": "^41.7.8",
		"vite": "^6.3.5",
		"vitepress-demo-plugin": "^1.4.7",
		"vitest": "^3.2.4",
		"vue": "^3.5.18",
		"vue-tsc": "^2.2.12"
	},
	"dependencies": {
		"@dotenvx/dotenvx": "^1.49.0"
	}
}