{
	"name": "@ruan-cat-10wms/wms-frontend-origin",
	"version": "0.6.0",
	"type": "module",
	"description": "01星球大项目-10WMS项目。这里是WMS系统后台前端代码。",
	"scripts": {
		"dev": "turbo vite:dev",
		"build": "turbo do-build",
		"deploy": "tsx ./scripts/deploy.ts --env-path=.env.production",
		"preview": "vite preview",
		"test": "vitest --ui --watch --api.port=4000",
		"format": "prettier --experimental-cli --config=../prettier.config.js --ignore-path ../.gitignore --write .",
		"docs:dev": "turbo do-docs-dev",
		"docs:build": "turbo do-docs-build",
		"git:fetch": "git fetch -p",
		"git:push": "git push --follow-tags",
		"git:commit": "git-cz",
		"vite:dev": "vite --mode development",
		"clear:deps": "rimraf -g '**/{node_modules,pnpm-lock.yaml}'",
		"clear:cache": "rimraf -g '**/{dist,.turbo,.vercel,.cache,.temp}'",
		"changeset:add": "changeset add",
		"changeset:version": "changeset version && changeset tag",
		"notuse-up-ruan-cat": "pnpm up '@ruan-cat/*@latest'",
		"lint": "eslint --fix .",
		"corepack:pnpm": "corepack enable && corepack prepare pnpm@9.5.0 --activate",
		"notuse-preinstall": "npx only-allow pnpm && npm run corepack:pnpm",
		"rm:types": "tsx ./scripts/del-types.ts",
		"typedoc": "typedoc --options typedoc.config.mjs --tsconfig tsconfig.typedoc.json",
		"do-build": "vite build --mode production",
		"do-docs-dev": "vitepress dev src --port 8080",
		"do-docs-build": "vitepress build src"
	},
	"dependencies": {
		"@antfu/utils": "^9.3.0",
		"@element-plus/icons-vue": "^2.3.2",
		"@form-create/designer": "^3.4.0",
		"@form-create/element-ui": "^3.2.33",
		"@logicflow/core": "^2.2.0",
		"@logicflow/extension": "^2.2.0",
		"@vueuse/core": "^12.8.2",
		"@vueuse/integrations": "^12.8.2",
		"@wangeditor/editor": "^5.1.23",
		"@wangeditor/editor-for-vue": "^5.1.12",
		"axios": "^1.13.2",
		"crypto-js": "^4.2.0",
		"echarts": "^5.6.0",
		"element-plus": "^2.13.0",
		"git-cz": "^4.9.0",
		"lodash-es": "^4.17.22",
		"pdfobject": "^2.3.1",
		"pinia": "^3.0.4",
		"qs": "^6.14.0",
		"vue": "^3.5.26",
		"vue-i18n": "11.0.0-rc.1",
		"vue-plugin-hiprint": "0.0.58-fix",
		"vue-router": "^4.6.4",
		"xlsx": "https://cdn.sheetjs.com/xlsx-0.20.2/xlsx-0.20.2.tgz"
	},
	"devDependencies": {
		"@antfu/eslint-config": "^4.19.0",
		"@changesets/cli": "^2.29.8",
		"@ruan-cat/commitlint-config": "^4.9.0",
		"@ruan-cat/domains": "^1.7.0",
		"@ruan-cat/utils": "^4.20.0",
		"@ruan-cat/vercel-deploy-tool": "^1.2.3",
		"@ruan-cat/vite-plugin-ts-alias": "^0.2.0",
		"@ruan-cat/vitepress-preset-config": "^2.12.4",
		"@types/eslint-config-prettier": "^6.11.3",
		"@types/lodash-es": "^4.17.12",
		"@types/qs": "^6.14.0",
		"@vitejs/plugin-vue": "^5.2.4",
		"@vitest/ui": "^3.2.4",
		"@vue/eslint-config-prettier": "^10.2.0",
		"@vue/test-utils": "^2.4.6",
		"commitizen": "^4.3.1",
		"consola": "^3.4.2",
		"cpx": "^1.5.0",
		"cross-env": "^7.0.3",
		"cz-git": "^1.12.0",
		"del": "^8.0.1",
		"eslint": "^9.39.2",
		"eslint-config-prettier": "^10.1.8",
		"eslint-plugin-format": "^1.1.0",
		"eslint-plugin-prettier": "^5.5.4",
		"jsdom": "^26.1.0",
		"pinia-plugin-persistedstate": "^4.7.1",
		"postcss": "^8.5.6",
		"prettier": "^3.7.4",
		"prettier-plugin-lint-md": "^1.0.1",
		"sass-embedded": "^1.97.1",
		"tsx": "^4.21.0",
		"turbo": "^2.7.1",
		"type-plus": "^7.6.2",
		"typedoc": "0.28.0-beta.0",
		"typedoc-plugin-frontmatter": "^1.3.1",
		"typedoc-plugin-markdown": "^4.9.0",
		"typescript": "^5.9.3",
		"unplugin-auto-import": "^20.3.0",
		"unplugin-element-plus": "^0.11.2",
		"unplugin-icons": "^22.5.0",
		"unplugin-vue-components": "^30.0.0",
		"unplugin-vue-router": "^0.19.1",
		"vite": "^6.3.5",
		"vite-plugin-autogeneration-import-file": "^3.0.0",
		"vite-plugin-html": "^3.2.2",
		"vite-plugin-vercel": "^9.1.1",
		"vite-plugin-vue-devtools": "^7.7.9",
		"vite-plugin-vue-meta-layouts": "^0.5.1",
		"vitepress": "^1.6.4",
		"vitepress-demo-plugin": "^1.5.1",
		"vitest": "^3.2.4"
	}
}
